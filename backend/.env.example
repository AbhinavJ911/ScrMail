# ── MongoDB ──
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/scrmail

# ── Google OAuth 2.0 ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Session ──
SESSION_SECRET=your_random_session_secret

# ── Frontend URL ──
CLIENT_URL=http://localhost:5173

# ── Encryption (AES-256-GCM) ──
# Generate with: npm run generate-key
ENCRYPTION_KEY=your_64_char_hex_key_here

# ── Redis (optional for local, required for production) ──
# Upstash example: rediss://default:your_password@your_endpoint.upstash.io:6379
# REDIS_URL=

# ── Environment ──
# NODE_ENV=production
